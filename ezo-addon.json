{
  "schemaVersion": 1,
  "addon": {
    "id": "ezometter",
    "name": "EZOMetter",
    "version": "0.1.34",
    "stage": "beta",
    "status": "beta",
    "phase": "public-beta",
    "visibility": "public",
    "manifest": "EZOMetter.txt",
    "package": {
      "rootFolderName": "EZOMetter",
      "zipName": "EZOMetter_v0.1.34.zip",
      "outputPath": "dist",
      "include": [
        "*.txt",
        "*.lua",
        "*.xml",
        "modules/**",
        "lang/**",
        "libs/**",
        "media/**",
        "textures/**",
        "fonts/**",
        "bindings/**"
      ],
      "exclude": [
        ".codex/**",
        ".agents/**",
        ".cursor/**",
        ".github/**",
        ".git/**",
        ".vscode/**",
        ".env",
        ".env.*",
        "AGENTS.md",
        "dev/**",
        "docs/**",
        "local/**",
        "private/**",
        "scripts/**",
        "scratch/**",
        "tmp/**",
        "temp/**",
        "tests/**",
        "test/**",
        "node_modules/**",
        "build/**",
        "dist/**",
        "*.local*",
        "*.secret*",
        "secrets.*",
        "*.md",
        "*.ps1",
        "*.sh",
        "*.log",
        "*.tmp",
        "*.bak"
      ]
    }
  },
  "discord": {
    "webhookSecretNames": {
      "downloads": "EZO_CODEX_DOWNLOADS",
      "releases": "EZO_CODEX_RELEASES",
      "status": "EZO_CODEX_STATUS",
      "announcements": "EZO_CODEX_ANNOUNCER",
      "betaBuilds": "EZO_CODEX_BETA_BUILDS",
      "codexLog": "CODEX_LOG",
      "bugReports": "EZO_CODEX_BUG_REPORTS"
    }
  }
}
